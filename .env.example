# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# MONGODB_URI: Connection string for your MongoDB database.
# Configure this in the AI Studio Secrets panel.
# Example: mongodb+srv://username:password@cluster.mongodb.net/dbname
MONGODB_URI=

# Admin Credentials (optional customization, defaults to admin@olart.com and password123 if blank)
# Use ADMIN_EMAIL and ADMIN_PASSWORD if deploying a full-stack container.
# If deploying statically (e.g. Vercel), add NEXT_PUBLIC_ADMIN_EMAIL and NEXT_PUBLIC_ADMIN_PASSWORD instead.
ADMIN_EMAIL=
ADMIN_PASSWORD=
NEXT_PUBLIC_ADMIN_EMAIL=
NEXT_PUBLIC_ADMIN_PASSWORD=

